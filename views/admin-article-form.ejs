<%- include('partials/admin-layout-start') %>
<div class="admin-headline"><h1><%= item ? 'Edit Artikel' : 'Tambah Artikel' %></h1></div>
<form method="post" action="<%= ADMIN_ROUTE %>/articles/save" enctype="multipart/form-data" class="admin-form card-form">
  <input type="hidden" name="id" value="<%= item?.id || '' %>" />
  <input type="hidden" name="currentImage" value="<%= item?.coverImage || '' %>" />
  <div class="form-grid two-cols">
    <label>Judul<input type="text" name="title" value="<%= item?.title || '' %>" required /></label>
    <label>Slug<input type="text" name="slug" value="<%= item?.slug || '' %>" /></label>
    <label>Status<select name="status"><option value="draft" <%= item?.status==='draft'?'selected':'' %>>Draft</option><option value="publish" <%= item?.status==='publish'?'selected':'' %>>Publish</option><option value="nonpublish" <%= item?.status==='nonpublish'?'selected':'' %>>Nonpublish</option></select></label>
    <label>Cover Image<input type="file" name="coverImage" accept="image/*" /></label>
  </div>
  <label>Excerpt<textarea name="excerpt" rows="3"><%= item?.excerpt || '' %></textarea></label>
  <label>Content (boleh HTML sederhana)<textarea name="content" rows="10"><%= item?.content || '' %></textarea></label>
  <label>Keywords (satu baris satu keyword)<textarea name="keywords" rows="4"><%= item?.keywords?.join('\n') || '' %></textarea></label>
  <div class="form-grid two-cols">
    <label>Meta Title<input type="text" name="metaTitle" value="<%= item?.metaTitle || '' %>" /></label>
    <label>Meta Description<input type="text" name="metaDescription" value="<%= item?.metaDescription || '' %>" /></label>
  </div>
  <button class="btn btn-primary" type="submit">Simpan Artikel</button>
</form>
<%- include('partials/admin-layout-end') %>
