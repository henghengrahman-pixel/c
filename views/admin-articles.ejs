<%- include('partials/admin-layout-start') %>
<div class="admin-headline row-between"><div><h1>Artikel</h1><p>Kelola artikel dan status publish.</p></div><a class="btn btn-primary" href="<%= ADMIN_ROUTE %>/articles/new">Tambah Artikel</a></div>
<div class="table-card"><table><thead><tr><th>Judul</th><th>Status</th><th>Update</th><th>Aksi</th></tr></thead><tbody><% articles.forEach(function(item){ %><tr><td><%= item.title %></td><td><span class="pill"><%= item.status %></span></td><td><%= (item.updatedAt || '').slice(0,10) %></td><td><div class="table-actions"><a class="btn btn-soft small" href="<%= ADMIN_ROUTE %>/articles/edit/<%= item.id %>">Edit</a><form method="post" action="<%= ADMIN_ROUTE %>/articles/toggle/<%= item.id %>"><button class="btn btn-soft small" type="submit"><%= item.status === 'publish' ? 'Nonpublish' : 'Publish' %></button></form><form method="post" action="<%= ADMIN_ROUTE %>/articles/delete/<%= item.id %>" onsubmit="return confirm('Hapus artikel ini?');"><button class="btn btn-danger small" type="submit">Hapus</button></form></div></td></tr><% }) %></tbody></table></div>
<%- include('partials/admin-layout-end') %>
