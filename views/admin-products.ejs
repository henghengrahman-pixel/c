<%- include('partials/admin-layout-start') %>
<div class="admin-headline row-between"><div><h1>Produk</h1><p>Kelola produk, edit, hapus, publish, dan nonpublish.</p></div><a class="btn btn-primary" href="<%= ADMIN_ROUTE %>/products/new">Tambah Produk</a></div>
<div class="table-card"><table><thead><tr><th>Nama</th><th>Kategori</th><th>Status</th><th>Harga</th><th>Aksi</th></tr></thead><tbody><% products.forEach(function(item){ %><tr><td><%= item.name %></td><td><%= item.category %></td><td><span class="pill"><%= item.status %></span></td><td><%= formatRupiah(item.isPromo && item.promoPrice ? item.promoPrice : item.price) %></td><td><div class="table-actions"><a class="btn btn-soft small" href="<%= ADMIN_ROUTE %>/products/edit/<%= item.id %>">Edit</a><form method="post" action="<%= ADMIN_ROUTE %>/products/toggle/<%= item.id %>"><button class="btn btn-soft small" type="submit"><%= item.status === 'publish' ? 'Nonpublish' : 'Publish' %></button></form><form method="post" action="<%= ADMIN_ROUTE %>/products/delete/<%= item.id %>" onsubmit="return confirm('Hapus produk ini?');"><button class="btn btn-danger small" type="submit">Hapus</button></form></div></td></tr><% }) %></tbody></table></div>
<%- include('partials/admin-layout-end') %>
