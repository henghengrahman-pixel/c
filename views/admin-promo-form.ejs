<%- include('partials/admin-layout-start') %>
<div class="admin-headline"><h1><%= item ? 'Edit Promo' : 'Tambah Promo' %></h1></div>
<form method="post" action="<%= ADMIN_ROUTE %>/promos/save" enctype="multipart/form-data" class="admin-form card-form">
  <input type="hidden" name="id" value="<%= item?.id || '' %>" />
  <input type="hidden" name="currentImage" value="<%= item?.image || '' %>" />
  <div class="form-grid two-cols">
    <label>Judul Promo<input type="text" name="title" value="<%= item?.title || '' %>" required /></label>
    <label>Slug<input type="text" name="slug" value="<%= item?.slug || '' %>" /></label>
    <label>Tanggal Mulai<input type="date" name="startDate" value="<%= item?.startDate || '' %>" /></label>
    <label>Tanggal Selesai<input type="date" name="endDate" value="<%= item?.endDate || '' %>" /></label>
    <label>Status<select name="status"><option value="draft" <%= item?.status==='draft'?'selected':'' %>>Draft</option><option value="publish" <%= item?.status==='publish'?'selected':'' %>>Publish</option><option value="nonpublish" <%= item?.status==='nonpublish'?'selected':'' %>>Nonpublish</option></select></label>
    <label>Banner Promo<input type="file" name="image" accept="image/*" /></label>
    <label>Teks Tombol<input type="text" name="buttonText" value="<%= item?.buttonText || '' %>" /></label>
    <label>Link Tombol<input type="text" name="buttonLink" value="<%= item?.buttonLink || '' %>" /></label>
  </div>
  <label>Deskripsi<textarea name="description" rows="6"><%= item?.description || '' %></textarea></label>
  <div class="checkbox-row"><label><input type="checkbox" name="isFeatured" <%= item?.isFeatured ? 'checked' : '' %> /> Promo unggulan</label></div>
  <button class="btn btn-primary" type="submit">Simpan Promo</button>
</form>
<%- include('partials/admin-layout-end') %>
