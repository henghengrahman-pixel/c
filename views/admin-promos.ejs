<%- include('partials/admin-layout-start') %>
<div class="admin-headline row-between"><div><h1>Promo</h1><p>Kelola promo aktif dan nonaktif.</p></div><a class="btn btn-primary" href="<%= ADMIN_ROUTE %>/promos/new">Tambah Promo</a></div>
<div class="table-card"><table><thead><tr><th>Promo</th><th>Status</th><th>Periode</th><th>Aksi</th></tr></thead><tbody><% promos.forEach(function(item){ %><tr><td><%= item.title %></td><td><span class="pill"><%= item.status %></span></td><td><%= item.startDate || '-' %> - <%= item.endDate || '-' %></td><td><div class="table-actions"><a class="btn btn-soft small" href="<%= ADMIN_ROUTE %>/promos/edit/<%= item.id %>">Edit</a><form method="post" action="<%= ADMIN_ROUTE %>/promos/toggle/<%= item.id %>"><button class="btn btn-soft small" type="submit"><%= item.status === 'publish' ? 'Nonpublish' : 'Publish' %></button></form><form method="post" action="<%= ADMIN_ROUTE %>/promos/delete/<%= item.id %>" onsubmit="return confirm('Hapus promo ini?');"><button class="btn btn-danger small" type="submit">Hapus</button></form></div></td></tr><% }) %></tbody></table></div>
<%- include('partials/admin-layout-end') %>
