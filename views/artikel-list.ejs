<%- include('partials/head') %><%- include('partials/header') %>
<section class="inner-hero"><div class="container reveal"><h1>Artikel Catherine Slim</h1><p>Kumpulan artikel pendukung SEO dan edukasi website profesional.</p><form class="search-bar" method="get"><input type="text" name="q" value="<%= q %>" placeholder="Cari artikel..." /><button class="btn btn-primary" type="submit">Cari</button></form></div></section>
<section class="section"><div class="container"><div class="card-grid two-cols"><% articles.forEach(function(article){ %><article class="article-card reveal"><span class="pill">Artikel SEO</span><h3><a href="/artikel/<%= article.slug %>"><%= article.title %></a></h3><p><%= article.excerpt %></p><a class="text-link" href="/artikel/<%= article.slug %>">Baca selengkapnya</a></article><% }) %></div></div></section>
<%- include('partials/footer') %>
