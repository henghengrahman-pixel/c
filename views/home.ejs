<%- include('partials/head') %>
<%- include('partials/header') %>

<main>
  <section class="hero-section">
    <div class="container hero-grid">
      <div class="hero-copy reveal">
        <p class="eyebrow">Official Store</p>
        <h1><%= settings.heroTitle %></h1>
        <p class="hero-subtitle"><%= settings.heroSubtitle %></p>
        <p><%= settings.heroDescription %></p>
        <div class="hero-actions">
          <a href="/produk" class="btn btn-primary">Lihat Produk</a>
          <a href="<%= whatsappLink %>" target="_blank" rel="noopener" class="btn btn-secondary">Order via WhatsApp</a>
        </div>
      </div>
      <div class="hero-card reveal delay-1">
        <div class="glass-card">
          <h2>Cathrine Slim Original</h2>
          <p>
            Produk pelangsing yang membantu menjaga berat badan tetap ideal,
            mengontrol nafsu makan, dan mendukung gaya hidup sehat.
          </p>
          <ul class="hero-points">
            <li>Produk original</li>
            <li>Bisa konsultasi sebelum order</li>
            <li>Pengiriman seluruh Indonesia & Kamboja</li>
          </ul>
        </div>
      </div>
    </div>
    <div class="hero-glow"></div>
  </section>

  <section class="section">
    <div class="container section-heading reveal">
      <p class="eyebrow">Official Product</p>
      <h2>Produk Cathrine Slim</h2>
      <p>
        Pilih produk Cathrine Slim original dengan kualitas terbaik dan
        pemesanan mudah melalui WhatsApp. Produk dikemas rapi dan dikirim dengan aman.
      </p>
    </div>
    <div class="container product-grid two-col">
      <% products.forEach(function(product){ %>
        <article class="product-card reveal">
          <a href="/produk/<%= product.slug %>" class="card-media">
            <img src="<%= product.imageUrl %>" alt="<%= product.name %>" loading="lazy">
          </a>
          <div class="card-content">
            <p class="card-kicker"><%= product.category %></p>
            <h3><a href="/produk/<%= product.slug %>"><%= product.name %></a></h3>
            <p><%= product.shortDesc %></p>
            <div class="card-bottom">
              <strong><%= product.price %></strong>
              <a href="/produk/<%= product.slug %>" class="text-link">Lihat Detail</a>
            </div>
          </div>
        </article>
      <% }) %>
    </div>
  </section>

  <section class="section alt-section parallax-panel">
    <div class="container section-heading reveal">
      <p class="eyebrow">Kenapa Memilih Kami</p>
      <h2>Belanja Cathrine Slim lebih mudah dan terpercaya</h2>
      <p>
        Kami memberikan pengalaman belanja yang nyaman, tampilan website yang bersih,
        serta pelayanan cepat agar pelanggan bisa order dengan mudah dan aman.
      </p>
    </div>
    <div class="container feature-grid">
      <div class="feature-card reveal">
        <h3>Produk Original</h3>
        <p>Kami hanya menyediakan Cathrine Slim original dengan kualitas terjamin.</p>
      </div>
      <div class="feature-card reveal delay-1">
        <h3>Pelayanan Cepat</h3>
        <p>Order dan konsultasi langsung melalui WhatsApp dengan respon cepat.</p>
      </div>
      <div class="feature-card reveal delay-2">
        <h3>Pengiriman Aman</h3>
        <p>Produk dikemas dengan aman dan dikirim menggunakan jasa pengiriman terpercaya.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container section-heading reveal">
      <p class="eyebrow">Testimoni</p>
      <h2>Testimoni Pelanggan</h2>
    </div>
    <div class="container testimonial-grid">
      <% testimonials.forEach(function(item){ %>
        <article class="testimonial-card reveal">
          <img src="<%= item.imageUrl %>" alt="Testimoni <%= item.name %>" loading="lazy">
          <div>
            <h3><%= item.name %></h3>
            <span><%= item.city %></span>
            <p>“<%= item.quote %>”</p>
          </div>
        </article>
      <% }) %>
    </div>
  </section>

  <section class="section alt-section">
    <div class="container section-heading reveal">
      <p class="eyebrow">Artikel</p>
      <h2>Informasi dan Tips Seputar Diet</h2>
      <p>
        Baca berbagai informasi dan tips seputar diet, menjaga berat badan,
        dan gaya hidup sehat untuk membantu program diet Anda.
      </p>
    </div>
    <div class="container article-grid two-col">
      <% articles.forEach(function(article){ %>
        <article class="article-card reveal">
          <a href="/artikel/<%= article.slug %>" class="card-media">
            <img src="<%= article.coverImage %>" alt="<%= article.title %>" loading="lazy">
          </a>
          <div class="card-content">
            <h3><a href="/artikel/<%= article.slug %>"><%= article.title %></a></h3>
            <p><%= article.excerpt %></p>
            <a href="/artikel/<%= article.slug %>" class="text-link">Baca Artikel</a>
          </div>
        </article>
      <% }) %>
    </div>
  </section>

  <section class="section shipping-section">
    <div class="container section-heading reveal">
      <p class="eyebrow">Pengiriman</p>
      <h2><%= settings.shippingText %></h2>
    </div>
    <div class="container shipping-grid">
      <div class="shipping-card reveal">
        <img src="<%= settings.jntImage %>" alt="JNT" loading="lazy">
      </div>
      <div class="shipping-card reveal delay-1">
        <img src="<%= settings.sicepatImage %>" alt="SiCepat" loading="lazy">
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
