<%- include('partials/head') %>
<%- include('partials/header') %>

<section class="hero-section">
  <div class="container hero-grid reveal">
    <div class="hero-content">
      <span class="eyebrow">Official Store Catherine Slim</span>
      <h1><%= settings.heroTitle || 'Catherine Slim, pilihan tepat untuk gaya hidup lebih teratur' %></h1>
      <p class="hero-copy">
        <%= settings.heroSubtitle || 'Catherine Slim hadir dengan tampilan profesional, promo yang jelas, dan layanan konsultasi WhatsApp yang mudah diakses. Cocok untuk kamu yang ingin berbelanja dengan nyaman, cepat, dan lebih percaya diri.' %>
      </p>

      <div class="hero-actions">
        <a href="/produk" class="btn btn-primary">Lihat Produk</a>
        <a href="<%= whatsappLink %>" target="_blank" rel="noopener" class="btn btn-whatsapp">Chat WhatsApp</a>
      </div>

      <div class="trust-pills">
        <span>Promo jelas</span>
        <span>Layanan cepat</span>
        <span>Belanja lebih nyaman</span>
      </div>
    </div>

    <div class="hero-card glow-card">
      <div class="hero-badge">Catherine Slim</div>
      <h3>Tampilan clean, rapi, dan meyakinkan</h3>
      <p>
        Produk ditampilkan dengan gaya yang lebih profesional, mobile-friendly, dan mudah dipahami agar pengunjung nyaman saat melihat promo, membaca informasi, dan menghubungi admin.
      </p>

      <div class="shipping-logos">
        <span>J&amp;T</span>
        <span>Gojek</span>
        <span>SiCepat</span>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">Kenapa memilih Catherine Slim</span>
      <h2>Dirancang untuk tampilan brand yang lebih profesional</h2>
      <p class="section-copy">
        Catherine Slim hadir dengan konsep yang lebih rapi, promo yang mudah dilihat, dan informasi yang tertata agar pelanggan merasa lebih nyaman saat menjelajah website.
      </p>
    </div>

    <div class="card-grid three-cols">
      <article class="info-card reveal">
        <span class="badge">Tampilan</span>
        <h3>Desain lebih clean</h3>
        <p>Nuansa sage green, layout lega, dan tampilan yang lebih halus membuat website terasa lebih premium dan enak dilihat.</p>
      </article>

      <article class="info-card reveal">
        <span class="badge">Layanan</span>
        <h3>Chat admin lebih mudah</h3>
        <p>Tombol WhatsApp tampil jelas agar calon pembeli bisa langsung bertanya, konsultasi, atau melakukan pemesanan dengan cepat.</p>
      </article>

      <article class="info-card reveal">
        <span class="badge">Pengalaman</span>
        <h3>Nyaman di mobile</h3>
        <p>Semua section dibuat lebih ringan dan mobile-friendly supaya pengunjung tetap nyaman membuka website dari handphone.</p>
      </article>
    </div>
  </div>
</section>

<section class="section alt-section">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">Promo pilihan</span>
      <h2>Penawaran yang tampil lebih jelas dan menarik</h2>
      <p class="section-copy">
        Promo ditampilkan dengan susunan yang rapi agar pelanggan lebih mudah melihat penawaran aktif, paket hemat, dan informasi penting lainnya.
      </p>
    </div>

    <div class="card-grid three-cols">
      <% if (promos && promos.length) { %>
        <% promos.forEach(function(item){ %>
          <article class="info-card reveal">
            <span class="badge">Promo</span>
            <h3><a href="/promo/<%= item.slug %>"><%= item.title %></a></h3>
            <p><%= item.description %></p>
            <a class="text-link" href="/promo/<%= item.slug %>"><%= item.buttonText || 'Lihat promo' %></a>
          </article>
        <% }) %>
      <% } else { %>
        <article class="info-card reveal">
          <span class="badge">Promo</span>
          <h3>Promo segera hadir</h3>
          <p>Kamu bisa menampilkan promo aktif di area ini agar pengunjung langsung melihat penawaran terbaik sejak pertama membuka website.</p>
          <a class="text-link" href="/promo">Lihat halaman promo</a>
        </article>
      <% } %>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">Produk unggulan</span>
      <h2>Pilihan produk yang ditampilkan lebih rapi</h2>
      <p class="section-copy">
        Susunan produk dibuat lebih nyaman dibaca dengan informasi singkat, harga, status promo, dan tombol detail yang jelas.
      </p>
    </div>

    <div class="card-grid three-cols">
      <% if (products && products.length) { %>
        <% products.forEach(function(product){ %>
          <article class="product-card reveal">
            <div class="product-thumb">
              <span>CS</span>
            </div>

            <div class="product-body">
              <div class="row-between">
                <span class="pill"><%= product.category || 'Produk' %></span>
                <% if (product.isPromo) { %>
                  <span class="badge"><%= product.promoLabel || 'Promo' %></span>
                <% } %>
              </div>

              <h3><a href="/produk/<%= product.slug %>"><%= product.name %></a></h3>
              <p><%= product.shortDesc %></p>

              <div class="price-wrap">
                <% if (product.isPromo && product.promoPrice) { %>
                  <strong><%= formatRupiah(product.promoPrice) %></strong>
                  <del><%= formatRupiah(product.price) %></del>
                <% } else { %>
                  <strong><%= formatRupiah(product.price) %></strong>
                <% } %>
              </div>

              <a class="btn btn-soft full-width" href="/produk/<%= product.slug %>">Detail Produk</a>
            </div>
          </article>
        <% }) %>
      <% } else { %>
        <article class="product-card reveal">
          <div class="product-thumb"><span>CS</span></div>
          <div class="product-body">
            <div class="row-between">
              <span class="pill">Produk</span>
            </div>
            <h3><a href="/produk">Produk Catherine Slim</a></h3>
            <p>Tambahkan produk unggulan di admin agar homepage terlihat lebih hidup, lebih profesional, dan lebih siap untuk jualan.</p>
            <a class="btn btn-soft full-width" href="/produk">Lihat Produk</a>
          </div>
        </article>
      <% } %>
    </div>
  </div>
</section>

<section class="section alt-section">
  <div class="container split-section reveal">
    <div>
      <span class="eyebrow">Layanan & pengiriman</span>
      <h2>Belanja lebih praktis dengan dukungan layanan yang jelas</h2>
      <p class="section-copy">
        Website juga menampilkan informasi layanan dan pengiriman dengan gaya yang lebih clean agar pelanggan merasa lebih tenang saat berbelanja.
      </p>

      <ul class="check-list">
        <li>Konsultasi cepat melalui WhatsApp</li>
        <li>Tampilan promo dan produk lebih mudah dipahami</li>
        <li>Informasi brand terlihat lebih profesional</li>
        <li>Nyaman diakses dari desktop maupun handphone</li>
      </ul>
    </div>

    <div class="glass-box">
      <h3>Didukung pengiriman praktis</h3>
      <p>
        Tampilkan layanan pengiriman dengan susunan yang lebih rapi agar pengunjung langsung mengetahui opsi yang tersedia.
      </p>

      <div class="shipping-logos spaced">
        <span>J&amp;T</span>
        <span>Gojek</span>
        <span>SiCepat</span>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">Artikel terbaru</span>
      <h2>Informasi dan inspirasi yang disusun lebih rapi</h2>
      <p class="section-copy">
        Halaman artikel membantu pengunjung menemukan informasi yang relevan sekaligus membuat website terasa lebih aktif, lengkap, dan terpercaya.
      </p>
    </div>

    <div class="card-grid two-cols">
      <% if (articles && articles.length) { %>
        <% articles.forEach(function(article){ %>
          <article class="article-card reveal">
            <span class="pill">Artikel</span>
            <h3><a href="/artikel/<%= article.slug %>"><%= article.title %></a></h3>
            <p><%= article.excerpt %></p>
            <a class="text-link" href="/artikel/<%= article.slug %>">Baca artikel</a>
          </article>
        <% }) %>
      <% } else { %>
        <article class="article-card reveal">
          <span class="pill">Artikel</span>
          <h3><a href="/artikel">Artikel Catherine Slim</a></h3>
          <p>Tambahkan artikel informatif agar website terasa lebih hidup dan pengunjung punya alasan untuk kembali membaca halaman lain.</p>
          <a class="text-link" href="/artikel">Lihat artikel</a>
        </article>
      <% } %>
    </div>
  </div>
</section>

<section class="section cta-section">
  <div class="container cta-box reveal">
    <div>
      <span class="eyebrow">Hubungi kami</span>
      <h2>Siap melihat produk dan promo terbaik hari ini?</h2>
      <p>
        Jelajahi produk Catherine Slim, lihat promo yang sedang aktif, atau langsung hubungi admin untuk mendapatkan informasi lebih lanjut dengan lebih cepat.
      </p>
    </div>

    <div class="cta-actions">
      <a href="/produk" class="btn btn-primary">Lihat Produk</a>
      <a href="<%= whatsappLink %>" target="_blank" rel="noopener" class="btn btn-whatsapp">Chat WhatsApp</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
