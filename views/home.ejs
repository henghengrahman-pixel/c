<%- include('partials/head') %>
<%- include('partials/header') %>

<section class="hero-section">
  <div class="container hero-grid reveal">
    <div class="hero-content">
      <span class="eyebrow">Official Store Catherine Slim</span>
      <h1>Catherine Slim Original – Obat Diet yang Banyak Dicari untuk Membantu Menjaga Berat Badan</h1>
      <p class="hero-copy">
        Catherine Slim merupakan produk diet yang banyak digunakan untuk membantu menjaga pola makan dan membantu mengontrol berat badan.
        Di website ini kamu bisa melihat produk Catherine Slim Original, promo terbaru, serta melakukan pemesanan langsung melalui WhatsApp dengan mudah dan cepat.
      </p>

      <div class="hero-actions">
        <a href="/produk" class="btn btn-primary">Lihat Produk</a>
        <a href="<%= whatsappLink %>" target="_blank" rel="noopener" class="btn btn-whatsapp">Chat WhatsApp</a>
      </div>

      <div class="trust-pills">
        <span>Promo Catherine Slim</span>
        <span>Pemesanan mudah</span>
        <span>Pengiriman cepat</span>
      </div>
    </div>

    <div class="hero-card glow-card">
      <div class="hero-badge">Catherine Slim</div>
      <h3>Obat diet populer</h3>
      <p>
        Catherine Slim dikenal sebagai salah satu produk diet yang banyak dicari oleh orang yang ingin menjaga berat badan dan pola makan.
        Kamu bisa melihat produk, promo, dan melakukan pemesanan langsung melalui WhatsApp.
      </p>

      <div class="shipping-logos">
        <span>J&T</span>
        <span>Gojek</span>
        <span>SiCepat</span>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">Kenapa memilih Catherine Slim</span>
      <h2>Catherine Slim merupakan produk diet yang banyak dicari</h2>
      <p class="section-copy">
        Banyak orang memilih Catherine Slim karena praktis digunakan dan menjadi salah satu produk diet yang populer.
        Kamu juga bisa konsultasi terlebih dahulu sebelum membeli melalui WhatsApp.
      </p>
    </div>

    <div class="card-grid three-cols">
      <article class="info-card reveal">
        <span class="badge">Produk</span>
        <h3>Produk diet populer</h3>
        <p>
          Catherine Slim dikenal sebagai salah satu produk diet yang banyak dicari oleh orang yang ingin menjaga berat badan dan pola makan.
        </p>
      </article>

      <article class="info-card reveal">
        <span class="badge">Konsultasi</span>
        <h3>Bisa konsultasi sebelum membeli</h3>
        <p>
          Kamu bisa bertanya terlebih dahulu tentang Catherine Slim, cara minum Catherine Slim, dan paket yang tersedia sebelum melakukan pemesanan.
        </p>
      </article>

      <article class="info-card reveal">
        <span class="badge">Pengiriman</span>
        <h3>Pengiriman cepat</h3>
        <p>
          Pengiriman dilakukan melalui jasa pengiriman seperti J&T, SiCepat, dan pengiriman instan sesuai lokasi.
        </p>
      </article>
    </div>
  </div>
</section>

<section class="section alt-section">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">Promo Catherine Slim</span>
      <h2>Promo Catherine Slim dan paket hemat</h2>
      <p class="section-copy">
        Kami menyediakan promo Catherine Slim dan paket hemat dengan harga lebih terjangkau.
        Silakan cek promo yang sedang aktif atau hubungi admin untuk mendapatkan penawaran terbaru.
      </p>
    </div>

    <div class="card-grid three-cols">
      <% if (promos && promos.length) { %>
        <% promos.forEach(function(item){ %>
          <article class="info-card reveal">
            <span class="badge">Promo</span>
            <h3><a href="/promo/<%= item.slug %>"><%= item.title %></a></h3>
            <p><%= item.description %></p>
            <a class="text-link" href="/promo/<%= item.slug %>">Lihat promo</a>
          </article>
        <% }) %>
      <% } else { %>
        <article class="info-card reveal">
          <span class="badge">Promo</span>
          <h3>Promo Catherine Slim</h3>
          <p>Promo Catherine Slim akan ditampilkan di halaman ini. Hubungi admin untuk mendapatkan harga promo terbaru.</p>
          <a class="text-link" href="/promo">Lihat promo</a>
        </article>
      <% } %>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">Produk Catherine Slim</span>
      <h2>Pilihan paket Catherine Slim Original</h2>
      <p class="section-copy">
        Berikut beberapa pilihan paket Catherine Slim Original yang bisa kamu pilih sesuai kebutuhan.
        Tersedia produk satuan dan paket hemat Catherine Slim dengan harga promo.
      </p>
    </div>

    <div class="card-grid three-cols">
      <% if (products && products.length) { %>
        <% products.forEach(function(product){ %>
          <article class="product-card reveal">
            <div class="product-thumb">
              <span>CS</span>
            </div>

            <div class="product-body">
              <div class="row-between">
                <span class="pill"><%= product.category || 'Produk' %></span>
                <% if (product.isPromo) { %>
                  <span class="badge">Promo</span>
                <% } %>
              </div>

              <h3><a href="/produk/<%= product.slug %>"><%= product.name %></a></h3>
              <p><%= product.shortDesc %></p>

              <div class="price-wrap">
                <% if (product.isPromo && product.promoPrice) { %>
                  <strong><%= formatRupiah(product.promoPrice) %></strong>
                  <del><%= formatRupiah(product.price) %></del>
                <% } else { %>
                  <strong><%= formatRupiah(product.price) %></strong>
                <% } %>
              </div>

              <a class="btn btn-soft full-width" href="/produk/<%= product.slug %>">Detail Produk</a>
            </div>
          </article>
        <% }) %>
      <% } %>
    </div>
  </div>
</section>

<section class="section alt-section">
  <div class="container split-section reveal">
    <div>
      <span class="eyebrow">Pemesanan Catherine Slim</span>
      <h2>Pemesanan Catherine Slim lebih mudah</h2>
      <p class="section-copy">
        Pemesanan Catherine Slim bisa dilakukan dengan mudah melalui WhatsApp.
        Kamu bisa bertanya terlebih dahulu mengenai produk, harga, promo, dan cara pemesanan.
      </p>

      <ul class="check-list">
        <li>Konsultasi Catherine Slim melalui WhatsApp</li>
        <li>Informasi harga dan promo Catherine Slim</li>
        <li>Pemesanan mudah dan cepat</li>
        <li>Pengiriman ke berbagai kota</li>
      </ul>
    </div>

    <div class="glass-box">
      <h3>Didukung pengiriman</h3>
      <p>
        Pengiriman Catherine Slim dilakukan melalui jasa pengiriman terpercaya seperti J&T, SiCepat, dan pengiriman instan.
      </p>

      <div class="shipping-logos spaced">
        <span>J&T</span>
        <span>Gojek</span>
        <span>SiCepat</span>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">Artikel Catherine Slim</span>
      <h2>Informasi Catherine Slim, obat diet, dan tips menurunkan berat badan</h2>
      <p class="section-copy">
        Halaman artikel berisi informasi tentang Catherine Slim, cara minum Catherine Slim, tips diet,
        serta informasi lain seputar obat diet dan menjaga berat badan.
      </p>
    </div>

    <div class="card-grid two-cols">
      <% if (articles && articles.length) { %>
        <% articles.forEach(function(article){ %>
          <article class="article-card reveal">
            <span class="pill">Artikel</span>
            <h3><a href="/artikel/<%= article.slug %>"><%= article.title %></a></h3>
            <p><%= article.excerpt %></p>
            <a class="text-link" href="/artikel/<%= article.slug %>">Baca artikel</a>
          </article>
        <% }) %>
      <% } %>
    </div>
  </div>
</section>

<section class="section cta-section">
  <div class="container cta-box reveal">
    <div>
      <span class="eyebrow">Pesan Catherine Slim</span>
      <h2>Ingin membeli Catherine Slim atau melihat promo terbaru?</h2>
      <p>
        Silakan lihat produk Catherine Slim yang tersedia atau hubungi admin melalui WhatsApp
        untuk pemesanan, informasi harga, dan promo Catherine Slim terbaru.
      </p>
    </div>

    <div class="cta-actions">
      <a href="/produk" class="btn btn-primary">Lihat Produk</a>
      <a href="<%= whatsappLink %>" target="_blank" rel="noopener" class="btn btn-whatsapp">Chat WhatsApp</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
