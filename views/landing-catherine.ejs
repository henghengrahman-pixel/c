<%- include('partials/head') %>
<%- include('partials/header') %>
<section class="inner-hero">
  <div class="container reveal">
    <span class="eyebrow">Keyword utama</span>
    <h1>Catherine Slim</h1>
    <p>Halaman pilar untuk brand Catherine Slim dengan fokus SEO, promo, FAQ, dan jalur konsultasi WhatsApp.</p>
  </div>
</section>
<section class="section"><div class="container split-section reveal"><div><h2>Kenapa halaman ini penting</h2><p>Halaman ini membantu Google mengenali Catherine Slim sebagai topik utama website. Isi sudah dibuat singkat, rapi, dan siap dihubungkan ke artikel pendukung.</p></div><div class="glass-box"><h3>Fokus isi</h3><ul class="check-list"><li>Informasi brand</li><li>Promo dan produk</li><li>FAQ singkat</li><li>Internal link ke artikel</li></ul></div></div></section>
<section class="section alt-section"><div class="container"><div class="section-head reveal"><h2>Produk terkait</h2></div><div class="card-grid three-cols"><% products.forEach(function(product){ %><article class="product-card reveal"><div class="product-thumb"><span>CS</span></div><div class="product-body"><h3><a href="/produk/<%= product.slug %>"><%= product.name %></a></h3><p><%= product.shortDesc %></p><a class="btn btn-soft full-width" href="/produk/<%= product.slug %>">Lihat Detail</a></div></article><% }) %></div></div></section>
<section class="section"><div class="container"><div class="section-head reveal"><h2>Artikel pendukung</h2></div><div class="card-grid two-cols"><% articles.forEach(function(article){ %><article class="article-card reveal"><h3><a href="/artikel/<%= article.slug %>"><%= article.title %></a></h3><p><%= article.excerpt %></p></article><% }) %></div></div></section>
<%- include('partials/footer') %>
