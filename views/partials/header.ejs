<% const cleanPath = (path || '').split('?')[0]; %>
<% const isActive = (value) => cleanPath === value || cleanPath.startsWith(value + '/'); %>
<% if (settings.topPromoActive) { %>
  <div class="top-promo-bar">
    <div class="container top-promo-inner">
      <span><%= settings.topPromoText %></span>
      <a href="<%= whatsappLink %>" target="_blank" rel="noopener">WhatsApp</a>
    </div>
  </div>
<% } %>
<header class="site-header" id="siteHeader">
  <div class="container header-inner">
    <a href="/" class="brand-mark">
      <span class="brand-logo">CS</span>
      <span class="brand-text-wrap">
        <strong><%= settings.logoText || settings.siteName %></strong>
        <small>Website profesional &amp; SEO terarah</small>
      </span>
    </a>
    <nav class="main-nav">
      <a class="<%= cleanPath === '/' ? 'active' : '' %>" href="/">Beranda</a>
      <a class="<%= isActive('/catherine-slim') ? 'active' : '' %>" href="/catherine-slim">Catherine Slim</a>
      <a class="<%= isActive('/obat-diet') ? 'active' : '' %>" href="/obat-diet">Obat Diet</a>
      <a class="<%= isActive('/artikel') ? 'active' : '' %>" href="/artikel">Artikel</a>
      <a class="<%= isActive('/promo') ? 'active' : '' %>" href="/promo">Promo</a>
      <a class="<%= isActive('/faq') ? 'active' : '' %>" href="/faq">FAQ</a>
      <a class="<%= isActive('/kontak') ? 'active' : '' %>" href="/kontak">Kontak</a>
    </nav>
    <div class="header-actions">
      <a href="<%= whatsappLink %>" target="_blank" rel="noopener" class="btn btn-whatsapp">WhatsApp</a>
    </div>
  </div>
</header>
