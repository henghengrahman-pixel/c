<% const cleanPath = (path || '').split('?')[0]; %>
<% const isActive = (value) => cleanPath === value || cleanPath.startsWith(value + '/'); %>

<% if (settings.topPromoActive) { %>
  <div class="top-promo-bar">
    <div class="container top-promo-inner">
      <span><%= settings.topPromoText || 'Promo spesial tersedia hari ini' %></span>
    </div>
  </div>
<% } %>

<header class="site-header" id="siteHeader">
  <div class="container header-inner">
    <a href="/" class="brand-mark" aria-label="<%= settings.siteName || 'Catherine Slim' %>">
      <span class="brand-logo brand-logo-text"><%= (settings.logoText || 'CS').slice(0, 2).toUpperCase() %></span>
      <span class="brand-text-wrap">
        <strong><%= settings.logoText || settings.siteName || 'Catherine Slim' %></strong>
        <small><%= settings.tagline || 'Official Store' %></small>
      </span>
    </a>

    <nav class="main-nav" aria-label="Navigasi utama">
      <a class="<%= cleanPath === '/' ? 'active' : '' %>" href="/">Beranda</a>
      <a class="<%= isActive('/produk') ? 'active' : '' %>" href="/produk">Produk</a>
      <a class="<%= isActive('/promo') ? 'active' : '' %>" href="/promo">Promo</a>
      <a class="<%= isActive('/artikel') ? 'active' : '' %>" href="/artikel">Artikel</a>
      <a class="<%= isActive('/faq') ? 'active' : '' %>" href="/faq">FAQ</a>
      <a class="<%= isActive('/kontak') ? 'active' : '' %>" href="/kontak">Kontak</a>
    </nav>

    <div class="header-actions">
      <a href="<%= whatsappLink %>" target="_blank" rel="noopener" class="btn btn-whatsapp">Chat WhatsApp</a>
    </div>
  </div>
</header>
