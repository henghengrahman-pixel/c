<%- include('partials/head') %><%- include('partials/header') %>
<section class="inner-hero"><div class="container reveal"><span class="eyebrow"><%= product.category %></span><h1><%= product.name %></h1><p><%= product.shortDesc %></p></div></section>
<section class="section"><div class="container detail-grid"><div class="detail-card reveal"><div class="product-thumb big"><span>CS</span></div><div class="shipping-logos spaced"><span>J&amp;T</span><span>Gojek</span><span>SiCepat</span></div></div><div class="detail-card reveal"><div class="price-wrap big"><% if (product.isPromo && product.promoPrice) { %><strong><%= formatRupiah(product.promoPrice) %></strong><del><%= formatRupiah(product.price) %></del><% } else { %><strong><%= formatRupiah(product.price) %></strong><% } %></div><p><%= product.desc %></p><div class="hero-actions"><a href="<%= whatsappLink %>" class="btn btn-whatsapp" target="_blank" rel="noopener">Pesan via WhatsApp</a><a href="/promo" class="btn btn-soft">Lihat Promo</a></div><% if (product.benefits?.length) { %><h3>Keunggulan</h3><ul class="check-list"><% product.benefits.forEach(function(item){ %><li><%= item %></li><% }) %></ul><% } %><% if (product.usage?.length) { %><h3>Cara pakai</h3><ul class="check-list"><% product.usage.forEach(function(item){ %><li><%= item %></li><% }) %></ul><% } %></div></div></section>
<section class="section alt-section"><div class="container"><div class="section-head reveal"><h2>Produk rekomendasi lain</h2></div><div class="card-grid three-cols"><% related.forEach(function(item){ %><article class="product-card reveal"><div class="product-thumb"><span>CS</span></div><div class="product-body"><h3><a href="/produk/<%= item.slug %>"><%= item.name %></a></h3><p><%= item.shortDesc %></p></div></article><% }) %></div></div></section>
<%- include('partials/footer') %>
