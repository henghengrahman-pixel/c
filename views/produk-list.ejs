<%- include('partials/head') %><%- include('partials/header') %>
<section class="inner-hero"><div class="container reveal"><h1>Produk Catherine Slim</h1><p>Daftar produk dan paket promo dengan tampilan rapi dan SEO-friendly.</p><form class="search-bar" method="get"><input type="text" name="q" value="<%= q %>" placeholder="Cari produk..." /><button class="btn btn-primary" type="submit">Cari</button></form></div></section>
<section class="section"><div class="container"><div class="card-grid three-cols"><% products.forEach(function(product){ %><article class="product-card reveal"><div class="product-thumb"><span>CS</span></div><div class="product-body"><h3><a href="/produk/<%= product.slug %>"><%= product.name %></a></h3><p><%= product.shortDesc %></p><div class="price-wrap"><% if (product.isPromo && product.promoPrice) { %><strong><%= formatRupiah(product.promoPrice) %></strong><del><%= formatRupiah(product.price) %></del><% } else { %><strong><%= formatRupiah(product.price) %></strong><% } %></div><a class="btn btn-soft full-width" href="/produk/<%= product.slug %>">Lihat Detail</a></div></article><% }) %></div></div></section>
<%- include('partials/footer') %>
