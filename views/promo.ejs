<%- include('partials/head') %>
<%- include('partials/header') %>
<main class="page-main">
  <section class="page-hero small">
    <div class="container reveal">
      <p class="eyebrow">Promo</p>
      <h1>Promo Cathrine Slim</h1>
      <p>Halaman promo ini tidak tampil di home dan hanya muncul melalui menu header sesuai kebutuhan Anda.</p>
    </div>
  </section>
  <section class="section">
    <div class="container article-grid two-col">
      <% promos.forEach(function(item){ %>
        <article class="article-card reveal">
          <div class="card-content">
            <h2><%= item.title %></h2>
            <p><%= item.excerpt %></p>
            <div class="prose"><%- item.content %></div>
          </div>
        </article>
      <% }) %>
    </div>
  </section>
</main>
<%- include('partials/footer') %>
